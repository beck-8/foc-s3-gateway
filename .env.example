# Required — Wallet private key (with 0x prefix)
PRIVATE_KEY=0x...

# Network: mainnet or calibration (default: calibration)
NETWORK=calibration

# Authentication (optional — leave empty for open mode)
ACCESS_KEY=
SECRET_KEY=

# Server ports (default: 8333 for S3, 8334 for WebDAV)
PORT=8333
WEBDAV_PORT=8334

# Desired copies per uploaded file (default: 2)
COPIES=2

# Custom RPC endpoint (optional — auto-detected from NETWORK)
# RPC_URL=https://api.calibration.node.glif.io/rpc/v1
